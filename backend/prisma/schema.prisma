generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserStatus {
  ACTIVE
  INACTIVE
  BLOCKED
}

enum RoleCode {
  ADMIN
  MANAGER
  CASHIER
  BARISTA
}

enum TableStatus {
  FREE
  OPEN
  PAYMENT
  BLOCKED
}

enum CashSessionStatus {
  OPEN
  CLOSED
}

enum OrderStatus {
  OPEN
  PAID
  CANCELLED
}

enum PaymentMethod {
  CASH
  PIX
  TEF_CREDIT
  TEF_DEBIT
}

enum PaymentStatus {
  PENDING
  APPROVED
  DECLINED
  CANCELLED
}

model Company {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  tradeName String   @map("trade_name")
  document  String   @unique
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  stores     Store[]
  users      User[]
  categories Category[]
  products   Product[]

  @@map("companies")
}

model Store {
  id        String   @id @default(uuid()) @db.Uuid
  companyId String   @map("company_id") @db.Uuid
  name      String
  code      String
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  company      Company       @relation(fields: [companyId], references: [id], onDelete: Restrict)
  users        UserStore[]
  tables       CafeTable[]
  cashSessions CashSession[]
  orders       Order[]

  @@unique([companyId, code])
  @@index([companyId])
  @@map("stores")
}

model Role {
  id          String   @id @default(uuid()) @db.Uuid
  code        RoleCode @unique
  name        String
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  users       User[]

  @@map("roles")
}

model User {
  id           String     @id @default(uuid()) @db.Uuid
  companyId    String     @map("company_id") @db.Uuid
  roleId       String     @map("role_id") @db.Uuid
  name         String
  email        String
  passwordHash String     @map("password_hash")
  status       UserStatus @default(ACTIVE)
  lastLoginAt  DateTime?  @map("last_login_at")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  company       Company       @relation(fields: [companyId], references: [id], onDelete: Restrict)
  role          Role          @relation(fields: [roleId], references: [id], onDelete: Restrict)
  stores        UserStore[]
  refreshTokens RefreshToken[]
  cashSessions  CashSession[]
  orders        Order[]

  @@unique([companyId, email])
  @@index([companyId])
  @@index([roleId])
  @@map("users")
}

model UserStore {
  userId  String @map("user_id") @db.Uuid
  storeId String @map("store_id") @db.Uuid
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  store   Store  @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@id([userId, storeId])
  @@map("user_stores")
}

model RefreshToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime  @default(now()) @map("created_at")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

model Category {
  id        String   @id @default(uuid()) @db.Uuid
  companyId String   @map("company_id") @db.Uuid
  name      String
  code      String
  active    Boolean  @default(true)
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  company  Company  @relation(fields: [companyId], references: [id], onDelete: Restrict)
  products Product[]

  @@unique([companyId, code])
  @@index([companyId])
  @@map("categories")
}

model Product {
  id          String   @id @default(uuid()) @db.Uuid
  companyId   String   @map("company_id") @db.Uuid
  categoryId  String   @map("category_id") @db.Uuid
  code        String
  name        String
  description String?
  price       Decimal  @db.Decimal(12, 2)
  aliases     String[] @default([])
  favorite    Boolean  @default(false)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  company    Company     @relation(fields: [companyId], references: [id], onDelete: Restrict)
  category   Category    @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  orderItems OrderItem[]

  @@unique([companyId, code])
  @@index([companyId, categoryId])
  @@map("products")
}

model CafeTable {
  id        String      @id @default(uuid()) @db.Uuid
  storeId   String      @map("store_id") @db.Uuid
  number    Int
  name      String?
  status    TableStatus @default(FREE)
  seats     Int         @default(4)
  active    Boolean     @default(true)
  openedAt  DateTime?   @map("opened_at")
  createdAt DateTime    @default(now()) @map("created_at")
  updatedAt DateTime    @updatedAt @map("updated_at")

  store  Store   @relation(fields: [storeId], references: [id], onDelete: Restrict)
  orders Order[]

  @@unique([storeId, number])
  @@index([storeId, status])
  @@map("cafe_tables")
}

model CashSession {
  id            String            @id @default(uuid()) @db.Uuid
  storeId       String            @map("store_id") @db.Uuid
  operatorId    String            @map("operator_id") @db.Uuid
  status        CashSessionStatus @default(OPEN)
  openingAmount Decimal           @map("opening_amount") @db.Decimal(12, 2)
  closingAmount Decimal?          @map("closing_amount") @db.Decimal(12, 2)
  openedAt      DateTime          @default(now()) @map("opened_at")
  closedAt      DateTime?         @map("closed_at")
  openingNote   String?           @map("opening_note")
  closingNote   String?           @map("closing_note")

  store    Store   @relation(fields: [storeId], references: [id], onDelete: Restrict)
  operator User    @relation(fields: [operatorId], references: [id], onDelete: Restrict)
  orders   Order[]

  @@index([storeId, status])
  @@index([operatorId])
  @@map("cash_sessions")
}

model Order {
  id            String      @id @default(uuid()) @db.Uuid
  storeId       String      @map("store_id") @db.Uuid
  tableId       String?     @map("table_id") @db.Uuid
  cashSessionId String      @map("cash_session_id") @db.Uuid
  operatorId    String      @map("operator_id") @db.Uuid
  status        OrderStatus @default(OPEN)
  guestCount    Int         @default(0) @map("guest_count")
  subtotal      Decimal     @default(0) @db.Decimal(12, 2)
  discount      Decimal     @default(0) @db.Decimal(12, 2)
  total         Decimal     @default(0) @db.Decimal(12, 2)
  openedAt      DateTime    @default(now()) @map("opened_at")
  closedAt      DateTime?   @map("closed_at")
  notes         String?

  store       Store       @relation(fields: [storeId], references: [id], onDelete: Restrict)
  table       CafeTable?  @relation(fields: [tableId], references: [id], onDelete: Restrict)
  cashSession CashSession @relation(fields: [cashSessionId], references: [id], onDelete: Restrict)
  operator    User        @relation(fields: [operatorId], references: [id], onDelete: Restrict)
  items       OrderItem[]
  payments    Payment[]

  @@index([storeId, status])
  @@index([tableId, status])
  @@index([cashSessionId])
  @@map("orders")
}

model OrderItem {
  id         String   @id @default(uuid()) @db.Uuid
  orderId    String   @map("order_id") @db.Uuid
  productId  String   @map("product_id") @db.Uuid
  quantity   Int
  unitPrice  Decimal  @map("unit_price") @db.Decimal(12, 2)
  totalPrice Decimal  @map("total_price") @db.Decimal(12, 2)
  notes      String?
  createdAt  DateTime @default(now()) @map("created_at")

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([orderId])
  @@index([productId])
  @@map("order_items")
}

model Payment {
  id                String        @id @default(uuid()) @db.Uuid
  orderId           String        @map("order_id") @db.Uuid
  method            PaymentMethod
  status            PaymentStatus @default(PENDING)
  amount            Decimal       @db.Decimal(12, 2)
  externalId        String?       @map("external_id")
  nsu               String?
  authorizationCode String?       @map("authorization_code")
  cardBrand         String?       @map("card_brand")
  installments      Int?
  approvedAt        DateTime?     @map("approved_at")
  createdAt         DateTime      @default(now()) @map("created_at")

  order Order @relation(fields: [orderId], references: [id], onDelete: Restrict)

  @@index([orderId])
  @@index([status])
  @@map("payments")
}
